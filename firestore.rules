rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /entries/{doc} {
      allow read: if true;
      allow create: if true;
    }
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "nageljp27@gmail.com";
    }
  }
}